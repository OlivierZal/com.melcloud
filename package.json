{
  "name": "com.melcloud",
  "version": "44.1.0",
  "description": "MELCloud for Homey",
  "homepage": "https://github.com/OlivierZal/com.melcloud/",
  "bugs": {
    "url": "https://github.com/OlivierZal/com.melcloud/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OlivierZal/com.melcloud.git"
  },
  "license": "GPL-3.0-only",
  "author": "Olivier Zalmanski",
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "npm run build:assets && tsgo --project tsconfig.build.json",
    "build:assets": "npm run build:clean && npm run build:css && npm run build:public",
    "build:clean": "for d in widgets/*/public; do rm -f \"$d\"/{constants,dom,zones,homey-api}.mts \"$d\"/styles/dist.css; done",
    "build:constants": "for d in widgets/*/public; do cp node_modules/@olivierzal/melcloud-api/src/constants.ts \"$d/constants.mts\"; done && npm run format:fix",
    "build:css": "for d in widgets/*/public; do npx @tailwindcss/cli -i app.css -o \"$d/styles/dist.css\"; done",
    "build:public": "for d in widgets/*/public; do cp public/*.mts \"$d/\"; done && npm run build:constants",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "github:push": "npm run homey:validate && npm run lint:fix && npm run format:fix && git push",
    "homey:install": "npx homey app install",
    "homey:publish": "npx homey app publish",
    "homey:start": "npx homey app run --remote",
    "homey:validate": "npx homey app validate --level=publish",
    "lint": "node --max-old-space-size=8192 ./node_modules/eslint/bin/eslint.js .",
    "lint:fix": "npm run lint -- --fix",
    "test": "vitest run",
    "test:coverage": "npm test -- --coverage",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@olivierzal/melcloud-api": "^39.0.0",
    "homey-lib": "^2.50.2",
    "source-map-support": "^0.5.21",
    "temporal-polyfill": "^0.3.2"
  },
  "devDependencies": {
    "@eslint/css": "^1.3.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.0",
    "@eslint/markdown": "^8.0.2",
    "@html-eslint/eslint-plugin": "^0.61.0",
    "@html-eslint/parser": "^0.61.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@swc/core": "^1.15.33",
    "@tailwindcss/cli": "^4.3.0",
    "@types/homey": "npm:homey-apps-sdk-v3-types@^0.3.12",
    "@types/node": "^25.9.1",
    "@typescript/native-preview": "^7.0.0-dev.20260527.2",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/eslint-plugin": "^1.6.17",
    "apexcharts": "^5.13.0",
    "daisyui": "^5.5.20",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsdoc": "^63.0.2",
    "eslint-plugin-package-json": "^1.3.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-yml": "^3.4.0",
    "homey-apps-sdk-v3-types": "^0.3.12",
    "jiti": "^2.7.0",
    "jsonc-eslint-parser": "^3.1.0",
    "prettier": "^3.8.3",
    "prettier-plugin-packagejson": "^3.0.2",
    "tailwind-csstree": "^0.3.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.60",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
