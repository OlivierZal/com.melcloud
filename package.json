{
  "name": "com.melcloud",
  "version": "45.1.0",
  "description": "MELCloud for Homey",
  "homepage": "https://github.com/OlivierZal/com.melcloud/",
  "bugs": {
    "url": "https://github.com/OlivierZal/com.melcloud/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OlivierZal/com.melcloud.git"
  },
  "license": "GPL-3.0-only",
  "author": "Olivier Zalmanski",
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "npm run build:assets && node ./node_modules/@typescript/native/bin/tsc --project tsconfig.build.json",
    "build:assets": "node scripts/bundle.mjs",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "github:push": "npm run homey:validate && npm run lint:fix && npm run format:fix && git push",
    "homey:install": "npx homey app install",
    "homey:publish": "npx homey app publish",
    "homey:start": "npx homey app run --remote",
    "homey:validate": "npx homey app validate --level=publish",
    "lint": "node --max-old-space-size=8192 ./node_modules/eslint/bin/eslint.js .",
    "lint:fix": "npm run lint -- --fix",
    "test": "vitest run",
    "test:coverage": "npm test -- --coverage",
    "typecheck": "node ./node_modules/@typescript/native/bin/tsc --noEmit"
  },
  "dependencies": {
    "@olivierzal/melcloud-api": "41.1.0-alpha.1",
    "source-map-support": "^0.5.21",
    "temporal-polyfill": "^1.0.1"
  },
  "devDependencies": {
    "@eslint/css": "^1.4.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.1",
    "@eslint/markdown": "^8.0.3",
    "@html-eslint/eslint-plugin": "^0.63.0",
    "@html-eslint/parser": "^0.63.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@swc/core": "^1.15.43",
    "@types/homey": "npm:homey-apps-sdk-v3-types@^0.3.12",
    "@types/node": "^26.1.0",
    "@typescript/native": "npm:typescript@^7.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/eslint-plugin": "^1.6.20",
    "chart.js": "^4.5.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.0",
    "eslint-plugin-jsdoc": "^63.0.11",
    "eslint-plugin-package-json": "^1.5.0",
    "eslint-plugin-perfectionist": "^5.9.1",
    "eslint-plugin-unicorn": "^71.1.0",
    "eslint-plugin-yml": "^3.5.0",
    "homey-apps-sdk-v3-types": "^0.3.12",
    "homey-lib": "^2.50.5",
    "jiti": "^2.7.0",
    "jsonc-eslint-parser": "^3.1.0",
    "prettier": "^3.8.5",
    "prettier-plugin-packagejson": "^3.0.2",
    "typescript": "~6.0.3",
    "typescript-eslint": "8.62",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
