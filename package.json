{
  "name": "com.melcloud",
  "version": "44.0.0",
  "description": "MELCloud for Homey",
  "homepage": "https://github.com/OlivierZal/com.melcloud/",
  "bugs": {
    "url": "https://github.com/OlivierZal/com.melcloud/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OlivierZal/com.melcloud.git"
  },
  "license": "GPL-3.0-only",
  "author": "Olivier Zalmanski",
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "npm run build:assets && tsc --project tsconfig.build.json",
    "build:assets": "npm run build:clean && npm run build:css && npm run build:public",
    "build:clean": "for dir in widgets/ata-group-setting/public widgets/charts/public; do rm -f \"$dir\"/constants.mts \"$dir\"/dom.mts \"$dir\"/zones.mts \"$dir\"/homey-api.mts \"$dir\"/dist.css; done",
    "build:constants": "for dir in widgets/ata-group-setting/public widgets/charts/public; do grep -v sourceMappingURL node_modules/@olivierzal/melcloud-api/dist/constants.js > \"$dir/constants.mts\"; done && npm run format:fix",
    "build:css": "npx @tailwindcss/cli -i app.css -o widgets/ata-group-setting/public/dist.css && npx @tailwindcss/cli -i app.css -o widgets/charts/public/dist.css",
    "build:public": "for dir in widgets/ata-group-setting/public widgets/charts/public; do cp public/*.mts \"$dir/\"; done && npm run build:constants",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "github:push": "npm run homey:validate && npm run lint:fix && npm run format:fix && git push",
    "homey:install": "npx homey app install",
    "homey:publish": "npx homey app publish",
    "homey:start": "npx homey app run --remote",
    "homey:validate": "npx homey app validate --level=publish",
    "lint": "eslint .",
    "lint:fix": "npm run lint -- --fix",
    "test": "vitest run",
    "test:coverage": "npm test -- --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@olivierzal/melcloud-api": "^23.3.3",
    "homey-lib": "^2.49.0",
    "luxon": "^3.7.2"
  },
  "devDependencies": {
    "@eslint/css": "^1.1.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@eslint/markdown": "^8.0.1",
    "@html-eslint/eslint-plugin": "^0.59.0",
    "@html-eslint/parser": "^0.59.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@swc/core": "^1.15.24",
    "@tailwindcss/cli": "^4.2.2",
    "@types/homey": "npm:homey-apps-sdk-v3-types@^0.3.12",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/eslint-plugin": "^1.6.14",
    "apexcharts": "^5.10.4",
    "daisyui": "^5.5.19",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-package-json": "^0.91.1",
    "eslint-plugin-perfectionist": "^5.8.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-yml": "^3.3.1",
    "homey-apps-sdk-v3-types": "^0.3.12",
    "jiti": "^2.6.1",
    "jsonc-eslint-parser": "^3.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.2",
    "tailwind-csstree": "^0.3.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "8.58",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=22"
  }
}
